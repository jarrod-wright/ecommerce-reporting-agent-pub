# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — NEVER commit real keys.

# --- LLM inference ---
# Free Google AI Studio key (used when running the agent on Gemini).
GOOGLE_API_KEY=
# Anthropic key (only needed if running the primary path on Claude).
ANTHROPIC_API_KEY=

# --- Security (override these insecure defaults before any real deployment) ---
WEBHOOK_SECRET_KEY=
JWT_SECRET_KEY=

# --- Observability (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=Ecomm-Report-Agent-Dev
